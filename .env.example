# --- AI (opzionale, a pagamento) ---
# Di DEFAULT l'AI è SPENTA: si usano fallback deterministici (zero spesa).
# Mettere AI_ENABLED=1 per attivare la generazione AI reale (DNA, strutturazione bandi, strategia)
# via Vercel AI Gateway. Vedi lib/ai.ts (modello: openai/gpt-5-mini).
AI_ENABLED=

# --- Persistenza (futuro) ---
# Per ora la persistenza è in-memory (si azzera a freddo). Per persistenza reale cross-sessione
# provisionare un Postgres e ripristinare il layer drizzle (vedi lib/db/schema.ts e lib/store.ts).
DATABASE_URL=

# --- Google Drive (futuro, live) ---
# Quando l'automazione leggerà i file reali del Drive (oggi sintesi statica/mock).
GOOGLE_SERVICE_ACCOUNT_JSON=
DRIVE_BANDI_FOLDER_ID=
